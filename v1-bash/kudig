        else
            log_check_ok "磁盘趋势: 正常"
        fi
    fi
    
    # 4. 检查网络带宽趋势
    if [[ -f "$system_status" ]]; then
        local network_usage=$(awk '/^-+run sar -n DEV/,/^-+End of sar/{if($2 ~ /^[eth0|ens|enp]/) print $0}' "$system_status" 2>/dev/null | tail -1)
        if [[ -n "$network_usage" ]]; then
            local rx_kb=$(echo "$network_usage" | awk '{print $5}')
            local tx_kb=$(echo "$network_usage" | awk '{print $6}')
            if [[ "$rx_kb" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($rx_kb > 80000)}") )); then
                add_anomaly "$SEVERITY_WARNING" \
                    "网络接收带宽接近上限" \
                    "HIGH_RX_BANDWIDTH_TREND" \
                    "网络接收带宽 ${rx_kb} KB/s，接近容量上限" \
                    "system_status"
                log_check_warn "网络趋势: RX接近上限 (${rx_kb} KB/s)"
            else
                log_check_ok "网络趋势: 正常 (RX:${rx_kb} KB/s, TX:${tx_kb} KB/s)"
            fi
        else
            log_check_skip "网络趋势: 无法获取信息"
        fi
    fi
    
    # 5. 检查inode使用趋势
    if [[ -f "$disk_info" ]]; then
        local high_inode_disks=$(awk '{if($5+0 > 80) print $0}' "$disk_info" 2>/dev/null | wc -l || echo "0")
        if [[ $high_inode_disks -gt 0 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "inode使用率接近上限" \
                "HIGH_INODE_USAGE_TREND" \
                "检测到 $high_inode_disks 个磁盘inode使用率超过80%" \
                "disk_info"
            log_check_warn "inode趋势: 接近上限 ($high_inode_disks 个磁盘)"
        else
            log_check_ok "inode趋势: 正常"
        fi
    fi
}

check_high_availability() {
