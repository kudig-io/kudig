    fi
    
    # 3. 检查磁盘增长趋势
    if [[ -f "$disk_info" ]]; then
        local high_usage_disks=$(awk '{if($5+0 > 80) print $0}' "$disk_info" 2>/dev/null | wc -l || echo "0")
        if [[ $high_usage_disks -gt 0 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "磁盘使用率接近上限" \
                "HIGH_DISK_USAGE_TREND" \
                "检测到 $high_usage_disks 个磁盘使用率超过80%" \
                "disk_info"
