# 检测存储和文件系统异常
check_storage_filesystem() {
    log_section "存储和文件系统检查"
    
    local system_status="$DIAGNOSE_DIR/system_status"
    local dmesg_log="$DIAGNOSE_DIR/logs/dmesg.log"
    
    # 1. 检查磁盘IO等待时间
    if [[ -f "$system_status" ]]; then
        local io_wait=$(awk '/^-+run iostat/,/^-+End of iostat/{if($0 ~ /%iowait/) print $NF}' "$system_status" 2>/dev/null | head -1 || echo "0")
        io_wait=$(echo "$io_wait" | tr -d '[:space:]')
        
        if [[ "$io_wait" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($io_wait > 50)}") )); then
            add_anomaly "$SEVERITY_CRITICAL" \
                "磁盘IO等待时间过高" \
                "HIGH_DISK_IO_WAIT" \
                "磁盘IO等待时间为 ${io_wait}%，超过50%阈值" \
                "system_status"
            log_check_fail "磁盘IO等待: 过高 (${io_wait}%)"
        elif [[ "$io_wait" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($io_wait > 20)}") )); then
            add_anomaly "$SEVERITY_WARNING" \
                "磁盘IO等待时间偏高" \
                "ELEVATED_DISK_IO_WAIT" \
                "磁盘IO等待时间为 ${io_wait}%，超过20%阈值" \
                "system_status"
            log_check_warn "磁盘IO等待: 偏高 (${io_wait}%)"
        else
            log_check_ok "磁盘IO等待: 正常 (${io_wait}%)"
        fi
    else
        log_check_skip "磁盘IO等待: 无法获取信息"
    fi
    
    # 2. 检查文件系统挂载选项
    if [[ -f "$system_status" ]]; then
        local noatime_mounts=$(awk '/^-+run mount/,/^-+End of mount/{if($0 ~ /noatime/) print $0}' "$system_status" 2>/dev/null | wc -l || echo "0")
        local total_mounts=$(awk '/^-+run mount/,/^-+End of mount/{if($0 ~ /^\/dev\//) print $0}' "$system_status" 2>/dev/null | wc -l || echo "0")
        
        if [[ $total_mounts -gt 0 ]] && [[ $noatime_mounts -eq 0 ]]; then
            add_anomaly "$SEVERITY_INFO" \
                "建议使用noatime挂载选项" \
                "NO_NOATIME_MOUNT_OPTION" \
                "建议对数据盘使用noatime挂载选项以提升性能" \
                "system_status"
            log_check_warn "挂载选项: 建议使用noatime"
        else
            log_check_ok "挂载选项: 正常"
        fi
    fi
    
    # 3. 检查文件系统错误
    if [[ -f "$dmesg_log" ]]; then
        local fs_error_count=$(count_pattern_in_log "$dmesg_log" "EXT4-fs error")
        if [[ $fs_error_count -gt 0 ]]; then
            add_anomaly "$SEVERITY_CRITICAL" \
                "文件系统错误" \
                "FILESYSTEM_ERROR" \
                "检测到 $fs_error_count 次EXT4文件系统错误" \
                "logs/dmesg.log"
            log_check_fail "文件系统: 存在错误 ($fs_error_count 次)"
        else
            log_check_ok "文件系统: 无错误"
        fi
    fi
    
    # 4. 检查NFS挂载状态
    if [[ -f "$system_status" ]]; then
        local nfs_mounts=$(awk '/^-+run mount/,/^-+End of mount/{if($0 ~ /type nfs/) print $0}' "$system_status" 2>/dev/null | wc -l || echo "0")
        if [[ $nfs_mounts -gt 0 ]]; then
            local nfs_errors=$(count_pattern_in_log "$dmesg_log" "nfs: server")
            if [[ $nfs_errors -gt 10 ]]; then
                add_anomaly "$SEVERITY_WARNING" \
                    "NFS连接问题" \
                    "NFS_CONNECTION_ISSUES" \
                    "检测到 $nfs_errors 次NFS相关错误" \
                    "logs/dmesg.log"
                log_check_warn "NFS挂载: 存在连接问题 ($nfs_errors 次)"
            else
                log_check_ok "NFS挂载: 正常 ($nfs_mounts 个)"
            fi
        else
            log_check_skip "NFS挂载: 未使用"
        fi
    fi
}

