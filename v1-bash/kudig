# 检测性能指标异常
check_performance() {
    log_section "性能指标检查"
    
    local system_status="$DIAGNOSE_DIR/system_status"
    local memory_info="$DIAGNOSE_DIR/memory_info"
    
    # 1. 检查上下文切换率
    if [[ -f "$system_status" ]]; then
        local context_switches=$(awk '/^-+run vmstat/,/^-+End of vmstat/{if($0 ~ /^[ 0-9]+$/) print $NF}' "$system_status" 2>/dev/null | head -1 || echo "0")
        
        if [[ "$context_switches" =~ ^[0-9]+$ ]] && [[ $context_switches -gt 100000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "上下文切换率过高" \
                "HIGH_CONTEXT_SWITCH_RATE" \
                "每秒上下文切换 $context_switches 次，超过100000阈值" \
                "system_status"
            log_check_warn "上下文切换: 过高 ($context_switches 次/秒)"
        else
            log_check_ok "上下文切换: 正常 ($context_switches 次/秒)"
        fi
    else
        log_check_skip "上下文切换: 无法获取信息"
    fi
    
    # 2. 检查系统调用率
    if [[ -f "$system_status" ]]; then
        local syscalls=$(awk '/^-+run vmstat/,/^-+End of vmstat/{if($0 ~ /^[ 0-9]+$/) print $(NF-1)}' "$system_status" 2>/dev/null | head -1 || echo "0")
        
        if [[ "$syscalls" =~ ^[0-9]+$ ]] && [[ $syscalls -gt 500000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "系统调用率过高" \
                "HIGH_SYSCALL_RATE" \
                "每秒系统调用 $syscalls 次，超过500000阈值" \
                "system_status"
            log_check_warn "系统调用: 过高 ($syscalls 次/秒)"
        else
            log_check_ok "系统调用: 正常 ($syscalls 次/秒)"
        fi
    fi
    
    # 3. 检查缓存使用
    if [[ -f "$memory_info" ]]; then
        local cached=$(grep -oP 'Cached:\s*\K\d+' "$memory_info" 2>/dev/null | head -1 || echo "0")
        local total=$(grep -oP 'MemTotal:\s*\K\d+' "$memory_info" 2>/dev/null | head -1 || echo "1")
        
        if [[ $total -gt 0 ]]; then
            local cache_percent=$(awk "BEGIN {printf \"%.0f\", $cached / $total * 100}")
            if [[ $cache_percent -gt 80 ]]; then
                add_anomaly "$SEVERITY_INFO" \
                    "缓存使用率偏高" \
                    "HIGH_CACHE_USAGE" \
                    "缓存使用率 ${cache_percent}%，可能影响性能" \
                    "memory_info"
                log_check_warn "缓存使用: 偏高 (${cache_percent}%)"
            else
                log_check_ok "缓存使用: 正常 (${cache_percent}%)"
            fi
        fi
    fi
    
    # 4. 检查中断率
    if [[ -f "$system_status" ]]; then
        local interrupts=$(awk '/^-+run vmstat/,/^-+End of vmstat/{if($0 ~ /^[ 0-9]+$/) print $(NF-2)}' "$system_status" 2>/dev/null | head -1 || echo "0")
        
        if [[ "$interrupts" =~ ^[0-9]+$ ]] && [[ $interrupts -gt 50000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "中断率过高" \
                "HIGH_INTERRUPT_RATE" \
                "每秒中断 $interrupts 次，超过50000阈值" \
                "system_status"
            log_check_warn "中断: 过高 ($interrupts 次/秒)"
        else
            log_check_ok "中断: 正常 ($interrupts 次/秒)"
        fi
    fi
}

