check_security_audit() {
    log_section "安全审计检查"
    
    local auth_log="$DIAGNOSE_DIR/logs/auth.log"
    local system_info="$DIAGNOSE_DIR/system_info"
    
    # 1. 检查失败的登录尝试
    if [[ -f "$auth_log" ]]; then
        local failed_logins=$(grep -ci "failed login\|authentication failure\|invalid user" "$auth_log" 2>/dev/null || echo "0")
        if [[ $failed_logins -gt 50 ]]; then
            add_anomaly "$SEVERITY_CRITICAL" \
                "失败登录尝试过多" \
                "EXCESSIVE_FAILED_LOGINS" \
                "检测到 $failed_logins 次失败登录尝试，可能存在暴力破解" \
                "logs/auth.log"
            log_check_fail "失败登录: 过多 ($failed_logins 次)"
        elif [[ $failed_logins -gt 10 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "失败登录尝试" \
                "EXCESSIVE_FAILED_LOGINS" \
                "检测到 $failed_logins 次失败登录尝试" \
                "logs/auth.log"
            log_check_warn "失败登录: 有尝试 ($failed_logins 次)"
        else
            log_check_ok "失败登录: 正常"
        fi
    else
        log_check_skip "失败登录: 无法获取信息"
    fi
    
    # 2. 检查特权容器
    if [[ -f "$system_info" ]]; then
        local privileged_containers=$(safe_count "$system_info" "privileged: true\|--privileged")
        if [[ $privileged_containers -gt 0 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "检测到特权容器" \
                "PRIVILEGED_CONTAINER" \
                "检测到 $privileged_containers 个特权容器，存在安全风险" \
                "system_info"
            log_check_warn "特权容器: 发现 ($privileged_containers 个)"
        else
            log_check_ok "特权容器: 无"
        fi
    fi
    
    # 3. 检查root用户容器
    if [[ -f "$system_info" ]]; then
        local root_containers=$(safe_count "$system_info" "user: 0\|User: root")
        if [[ $root_containers -gt 5 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "root用户容器过多" \
                "ROOT_USER_CONTAINER" \
                "检测到 $root_containers 个以root用户运行的容器" \
                "system_info"
            log_check_warn "root容器: 过多 ($root_containers 个)"
        else
            log_check_ok "root容器: 正常"
        fi
    fi
    
    # 4. 检查敏感挂载
    if [[ -f "$system_info" ]]; then
        local sensitive_mounts=$(safe_count "$system_info" "/docker.sock\|/var/run/docker.sock\|/var/lib/kubelet/pki")
        if [[ $sensitive_mounts -gt 0 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "检测到敏感挂载" \
                "SENSITIVE_MOUNT" \
                "检测到 $sensitive_mounts 个敏感挂载，存在安全风险" \
                "system_info"
            log_check_warn "敏感挂载: 发现 ($sensitive_mounts 个)"
        else
            log_check_ok "敏感挂载: 无"
        fi
    fi
    
    # 5. 检查权限提升
    if [[ -f "$auth_log" ]]; then
        local sudo_attempts=$(grep -ci "sudo\|su\|privilege escalation" "$auth_log" 2>/dev/null | head -1 || echo "0")
        if [[ $sudo_attempts -gt 20 ]]; then
            add_anomaly "$SEVERITY_INFO" \
                "权限提升操作频繁" \
                "FREQUENT_PRIVILEGE_ESCALATION" \
                "检测到 $sudo_attempts 次权限提升操作" \
                "logs/auth.log"
            log_check_warn "权限提升: 频繁 ($sudo_attempts 次)"
        else
            log_check_ok "权限提升: 正常"
        fi
    fi
}

check_capacity_planning() {
    log_section "容量规划检查"
    
    local system_status="$DIAGNOSE_DIR/system_status"
    local disk_info="$DIAGNOSE_DIR/disk_info"
    
    # 1. 检查CPU使用趋势
    if [[ -f "$system_status" ]]; then
        local cpu_usage=$(awk '/^-+run mpstat/,/^-+End of mpstat/{if($0 ~ /all/) print $NF}' "$system_status" 2>/dev/null | head -1 || echo "0")
        cpu_usage=$(echo "$cpu_usage" | tr -d '[:space:]')
        if [[ "$cpu_usage" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($cpu_usage > 80)}") )); then
            add_anomaly "$SEVERITY_WARNING" \
                "CPU使用率接近上限" \
                "HIGH_CPU_USAGE_TREND" \
                "CPU平均使用率 ${cpu_usage}%，接近容量上限" \
                "system_status"
