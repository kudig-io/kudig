            log_check_ok "CPU趋势: 正常 (${cpu_usage}%)"
        fi
    else
        log_check_skip "CPU趋势: 无法获取信息"
    fi
    
    # 2. 检查内存使用趋势
    if [[ -f "$system_status" ]]; then
        local mem_usage=$(awk '/^-+run free/,/^-+End of free/{if($2=="Mem:") print $3/$2*100}' "$system_status" 2>/dev/null | head -1 || echo "0")
        if [[ "$mem_usage" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($mem_usage > 80)}") )); then
            add_anomaly "$SEVERITY_WARNING" \
