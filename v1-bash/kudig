    check_backup_recovery
    check_compliance
    check_monitoring_alerting
    
    echo -e "\n${BLUE}================================================================${NC}" >&2
    echo -e "${BLUE}  诊断结果汇总${NC}" >&2
    echo -e "${BLUE}================================================================${NC}" >&2
    
    # 生成报告
    generate_report
    
    # 根据异常数量返回退出码
    local critical_count=0
    if [[ ${#ANOMALIES[@]} -gt 0 ]]; then
        for anomaly in "${ANOMALIES[@]}"; do
            IFS='|' read -r severity _ _ _ _ <<< "$anomaly"
            if [[ "$severity" == "$SEVERITY_CRITICAL" ]]; then
                ((critical_count++)) || true
            fi
        done
    fi
    
    if [[ $critical_count -gt 0 ]]; then
        exit 2  # 有严重异常
    elif [[ ${#ANOMALIES[@]} -gt 0 ]]; then
        exit 1  # 有警告或提示
    else
        exit 0  # 无异常
    fi
}

# 执行主函数
main "$@"
