    # 5. 检查容器运行时健康状态
    local containerd_status=$(get_daemon_status "containerd")
    if [[ "$containerd_status" == "running" ]]; then
        log_check_ok "容器运行时: 健康"
    else
        add_anomaly "$SEVERITY_CRITICAL" \
            "容器运行时异常" \
            "CONTAINER_RUNTIME_UNHEALTHY" \
            "容器运行时状态: $containerd_status" \
            "daemon_status/containerd_status"
        log_check_fail "容器运行时: 异常 ($containerd_status)"
    fi
}

# 检测网络性能异常
check_network_performance() {
    log_section "网络性能检查"
    
    local network_info="$DIAGNOSE_DIR/network_info"
    local system_status="$DIAGNOSE_DIR/system_status"
    
    # 1. 检查网络错误率
    if [[ -f "$network_info" ]]; then
        local rx_errors=$(awk '/RX errors/{print $3}' "$network_info" 2>/dev/null | head -1 || echo "0")
        local tx_errors=$(awk '/TX errors/{print $3}' "$network_info" 2>/dev/null | head -1 || echo "0")
        
        if [[ "$rx_errors" =~ ^[0-9]+$ ]] && [[ $rx_errors -gt 100 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "网络接收错误过多" \
                "HIGH_RX_ERRORS" \
                "网络接收错误 $rx_errors 次" \
                "network_info"
            log_check_warn "网络RX错误: 过多 ($rx_errors 次)"
        elif [[ "$tx_errors" =~ ^[0-9]+$ ]] && [[ $tx_errors -gt 100 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "网络发送错误过多" \
                "HIGH_TX_ERRORS" \
                "网络发送错误 $tx_errors 次" \
                "network_info"
            log_check_warn "网络TX错误: 过多 ($tx_errors 次)"
        else
            log_check_ok "网络错误: 正常 (RX:$rx_errors, TX:$tx_errors)"
        fi
    fi
    
    # 2. 检查网络丢包率
    if [[ -f "$network_info" ]]; then
        local rx_dropped=$(awk '/RX dropped/{print $4}' "$network_info" 2>/dev/null | head -1 || echo "0")
        local tx_dropped=$(awk '/TX dropped/{print $4}' "$network_info" 2>/dev/null | head -1 || echo "0")
        
        if [[ "$rx_dropped" =~ ^[0-9]+$ ]] && [[ $rx_dropped -gt 1000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "网络接收丢包过多" \
                "HIGH_RX_DROPPED" \
                "网络接收丢包 $rx_dropped 次" \
                "network_info"
            log_check_warn "网络RX丢包: 过多 ($rx_dropped 次)"
        elif [[ "$tx_dropped" =~ ^[0-9]+$ ]] && [[ $tx_dropped -gt 1000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "网络发送丢包过多" \
                "HIGH_TX_DROPPED" \
                "网络发送丢包 $tx_dropped 次" \
                "network_info"
            log_check_warn "网络TX丢包: 过多 ($tx_dropped 次)"
        else
            log_check_ok "网络丢包: 正常 (RX:$rx_dropped, TX:$tx_dropped)"
        fi
    fi
    
    # 3. 检查TCP连接状态
    if [[ -f "$network_info" ]]; then
        local time_wait=$(grep -c "TIME_WAIT" "$network_info" 2>/dev/null || echo "0")
        if [[ $time_wait -gt 10000 ]]; then
            add_anomaly "$SEVERITY_WARNING" \
                "TIME_WAIT连接过多" \
                "EXCESSIVE_TIME_WAIT" \
                "TIME_WAIT状态连接 $time_wait 个，可能耗尽端口资源" \
                "network_info"
            log_check_warn "TIME_WAIT: 过多 ($time_wait 个)"
        else
            log_check_ok "TIME_WAIT: 正常 ($time_wait 个)"
        fi
    fi
    
    # 4. 检查网络带宽使用
    if [[ -f "$system_status" ]]; then
        local network_usage=$(awk '/^-+run sar -n DEV/,/^-+End of sar/{if($2 ~ /^[eth0|ens|enp]/) print $0}' "$system_status" 2>/dev/null | tail -1)
        if [[ -n "$network_usage" ]]; then
            local rx_kb=$(echo "$network_usage" | awk '{print $5}')
            local tx_kb=$(echo "$network_usage" | awk '{print $6}')
            
            if [[ "$rx_kb" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($rx_kb > 100000)}") )); then
                add_anomaly "$SEVERITY_INFO" \
                    "网络接收带宽使用率高" \
                    "HIGH_RX_BANDWIDTH" \
                    "网络接收带宽 ${rx_kb} KB/s" \
                    "system_status"
                log_check_warn "网络RX带宽: 偏高 (${rx_kb} KB/s)"
            else
                log_check_ok "网络带宽: 正常 (RX:${rx_kb} KB/s, TX:${tx_kb} KB/s)"
            fi
        else
            log_check_skip "网络带宽: 无法获取信息"
        fi
    fi
    
    # 5. 检查DNS解析
    if [[ -f "$network_info" ]]; then
        if ! pattern_exists "$network_info" "nameserver"; then
            add_anomaly "$SEVERITY_WARNING" \
                "DNS配置缺失" \
                "DNS_CONFIGURATION_MISSING" \
                "未检测到DNS服务器配置" \
                "network_info"
            log_check_warn "DNS配置: 缺失"
        else
            log_check_ok "DNS配置: 正常"
        fi
    fi
}

check_hardware_health() {
    log_section "硬件健康检查"
    
    local dmesg_log="$DIAGNOSE_DIR/logs/dmesg.log"
    local system_info="$DIAGNOSE_DIR/system_info"
    
    # 1. 检查CPU温度（如果有sensors命令输出）
    if [[ -f "$system_info" ]]; then
        if pattern_exists "$system_info" "Core.*temp"; then
            local cpu_temp=$(grep -oP 'Core \d+.*\+\K[0-9]+\.[0-9]+' "$system_info" 2>/dev/null | sort -rn | head -1 || echo "0")
            if [[ "$cpu_temp" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($cpu_temp > 85)}") )); then
                add_anomaly "$SEVERITY_CRITICAL" \
                    "CPU温度过高" \
                    "HIGH_CPU_TEMPERATURE" \
                    "CPU核心温度 ${cpu_temp}°C，超过85°C阈值" \
                    "system_info"
                log_check_fail "CPU温度: 过高 (${cpu_temp}°C)"
            elif [[ "$cpu_temp" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(awk "BEGIN {print ($cpu_temp > 70)}") )); then
                add_anomaly "$SEVERITY_WARNING" \
                    "CPU温度偏高" \
                    "ELEVATED_CPU_TEMPERATURE" \
                    "CPU核心温度 ${cpu_temp}°C，超过70°C阈值" \
                    "system_info"
                log_check_warn "CPU温度: 偏高 (${cpu_temp}°C)"
            else
                log_check_ok "CPU温度: 正常 (${cpu_temp}°C)"
            fi
        else
            log_check_skip "CPU温度: 无法获取信息"
        fi
    fi
    
    # 2. 检查内存错误（ECC错误）
    if [[ -f "$dmesg_log" ]]; then
        local ecc_errors=$(safe_count "$dmesg_log" "ecc\|memory error\|mce")
        if [[ $ecc_errors -gt 0 ]]; then
            add_anomaly "$SEVERITY_CRITICAL" \
                "内存ECC错误" \
                "MEMORY_ECC_ERROR" \
                "检测到 $ecc_errors 条内存ECC错误记录" \
                "logs/dmesg.log"
            log_check_fail "内存ECC: 发现错误 ($ecc_errors 条)"
        else
            log_check_ok "内存ECC: 正常"
        fi
    fi
    
    # 3. 检查磁盘SMART健康状态
    if [[ -f "$system_info" ]]; then
        local smart_failures=$(safe_count "$system_info" "SMART overall-health self-assessment test result: FAILED")
        if [[ $smart_failures -gt 0 ]]; then
            add_anomaly "$SEVERITY_CRITICAL" \
                "磁盘SMART健康检测失败" \
                "DISK_SMART_FAILURE" \
                "检测到 $smart_failures 个磁盘SMART健康检测失败" \
                "system_info"
            log_check_fail "磁盘SMART: 健康检测失败"
        else
            local smart_warnings=$(safe_count "$system_info" "Pre-fail\|Old_age")
            if [[ $smart_warnings -gt 0 ]]; then
                add_anomaly "$SEVERITY_WARNING" \
                    "磁盘SMART预警" \
                    "DISK_SMART_WARNING" \
                    "检测到 $smart_warnings 条磁盘SMART预警信息" \
                    "system_info"
                log_check_warn "磁盘SMART: 有预警 ($smart_warnings 条)"
            else
                log_check_ok "磁盘SMART: 健康"
            fi
        fi
    else
        log_check_skip "磁盘SMART: 无法获取信息"
    fi
    
    # 4. 检查硬件错误日志
    if [[ -f "$dmesg_log" ]]; then
        local hw_errors=$(safe_count "$dmesg_log" "hardware error\|mce\|machine check exception")
        if [[ $hw_errors -gt 0 ]]; then
            add_anomaly "$SEVERITY_CRITICAL" \
                "硬件错误日志" \
                "HARDWARE_ERROR_LOG" \
                "检测到 $hw_errors 条硬件错误日志" \
                "logs/dmesg.log"
            log_check_fail "硬件错误: 发现错误日志 ($hw_errors 条)"
        else
            log_check_ok "硬件错误: 无异常"
        fi
    fi
    
    # 5. 检查CPU频率降频
    if [[ -f "$system_info" ]]; then
        if pattern_exists "$system_info" "cpu MHz"; then
            local cpu_freq=$(grep "cpu MHz" "$system_info" 2>/dev/null | awk '{print $4}' | head -1 || echo "0")
            local max_freq=$(grep "model name" "$system_info" 2>/dev/null | grep -oP '@ \K[0-9]+\.[0-9]+GHz' | head -1 | sed 's/GHz//' || echo "0")
            if [[ "$max_freq" != "0" ]]; then
                local freq_ratio=$(awk "BEGIN {print ($cpu_freq / ($max_freq * 1000))}")
                if (( $(awk "BEGIN {print ($freq_ratio < 0.5)}") )); then
                    add_anomaly "$SEVERITY_WARNING" \
                        "CPU频率降频" \
                        "CPU_THROTTLING" \
                        "CPU当前频率 ${cpu_freq} MHz，可能是最大频率的 ${freq_ratio}" \
                        "system_info"
                    log_check_warn "CPU频率: 降频 (${cpu_freq} MHz)"
                else
                    log_check_ok "CPU频率: 正常 (${cpu_freq} MHz)"
                fi
            else
                log_check_skip "CPU频率: 无法获取最大频率"
            fi
        else
            log_check_skip "CPU频率: 无法获取信息"
        fi
    fi
}

check_application_layer() {
    log_section "应用层检查"
    
    local kubelet_log="$DIAGNOSE_DIR/logs/kubelet.log"
    local docker_info="$DIAGNOSE_DIR/docker_info"
    
    # 1. 检查Pod健康状态
