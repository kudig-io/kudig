# EditorConfig 配置
# 统一不同编辑器的代码风格
# https://editorconfig.org

root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell 脚本配置
[*.sh]
indent_style = space
indent_size = 4
max_line_length = 120

# Markdown 文档
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML 配置文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON 配置文件
[*.json]
indent_style = space
indent_size = 2
