#!/usr/bin/env bash

################################################################################
# Pre-commit Hook for kudig.sh
# 在代码提交前执行快速质量检查
################################################################################

set -euo pipefail

# 颜色定义
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# 检查结果标记
CHECK_FAILED=0

echo -e "${BLUE}=== Pre-commit Quality Check ===${NC}"
echo ""

# 获取待提交的 .sh 文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)

if [[ -z "$STAGED_FILES" ]]; then
    echo -e "${GREEN}✓ No shell scripts to check${NC}"
    exit 0
fi

echo "Checking files:"
for file in $STAGED_FILES; do
    echo "  - $file"
done
echo ""

# 1. ShellCheck 语法检查
echo -e "${BLUE}[1/3] Running ShellCheck...${NC}"
if command -v shellcheck >/dev/null 2>&1; then
    SHELLCHECK_FAILED=0
    for file in $STAGED_FILES; do
        if [[ -f "$file" ]]; then
            if ! shellcheck -x "$file"; then
                SHELLCHECK_FAILED=1
                CHECK_FAILED=1
            fi
        fi
    done
    
    if [[ $SHELLCHECK_FAILED -eq 0 ]]; then
        echo -e "${GREEN}✓ ShellCheck passed${NC}"
    else
        echo -e "${RED}✗ ShellCheck found issues${NC}"
    fi
else
    echo -e "${YELLOW}⚠ ShellCheck not installed, skipping...${NC}"
    echo "  Install: https://github.com/koalaman/shellcheck#installing"
fi
echo ""

# 2. shfmt 格式检查
echo -e "${BLUE}[2/3] Running shfmt format check...${NC}"
if command -v shfmt >/dev/null 2>&1; then
    SHFMT_FAILED=0
    for file in $STAGED_FILES; do
        if [[ -f "$file" ]]; then
            if ! shfmt -d -i 4 -bn -ci -sr "$file"; then
                SHFMT_FAILED=1
                CHECK_FAILED=1
            fi
        fi
    done
    
    if [[ $SHFMT_FAILED -eq 0 ]]; then
        echo -e "${GREEN}✓ Format check passed${NC}"
    else
        echo -e "${RED}✗ Format issues found${NC}"
        echo -e "${YELLOW}  Tip: Run 'shfmt -w -i 4 -bn -ci -sr <file>' to auto-fix${NC}"
    fi
else
    echo -e "${YELLOW}⚠ shfmt not installed, skipping...${NC}"
    echo "  Install: https://github.com/mvdan/sh#shfmt"
fi
echo ""

# 3. 自定义规则检查
echo -e "${BLUE}[3/3] Running custom checks...${NC}"
if [[ -f "scripts/quality_check.sh" ]]; then
    if bash scripts/quality_check.sh $STAGED_FILES; then
        echo -e "${GREEN}✓ Custom checks passed${NC}"
    else
        CHECK_FAILED=1
        echo -e "${RED}✗ Custom checks failed${NC}"
    fi
else
    echo -e "${YELLOW}⚠ Custom check script not found, skipping...${NC}"
fi
echo ""

# 检查结果
echo -e "${BLUE}===================================${NC}"
if [[ $CHECK_FAILED -eq 1 ]]; then
    echo -e "${RED}✗ Pre-commit checks FAILED${NC}"
    echo ""
    echo "Please fix the issues above before committing."
    echo "To bypass this check (not recommended), use: git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}✓ All checks PASSED${NC}"
    exit 0
fi
