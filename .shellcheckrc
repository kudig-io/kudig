# ShellCheck 配置文件
# 用于 kudig.sh 项目的静态代码检查

# 启用所有检查
enable=all

# 排除特定规则
# SC2034: 未使用的变量 - 某些全局配置变量在声明时未立即使用
disable=SC2034

# SC1090: 无法跟踪动态source - 项目不使用动态source
disable=SC1090

# SC1091: 无法跟踪包含的文件 - 本项目为单文件脚本
disable=SC1091

# Shell 类型声明
shell=bash

# 严重级别阈值 - 检查所有级别的问题
severity=style

# 扩展全局变量检查
# 允许使用外部变量
external-sources=false
